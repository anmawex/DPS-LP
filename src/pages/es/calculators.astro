---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Calculator, RefreshCcw, TrendingDown, DollarSign, PiggyBank } from 'lucide-astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout title={`${t('calcPage.title')} | DRIVE POINT SOLUTIONS`}>
  <Navbar />

  <main>
        <!-- Hero Section -->
        <section class="bg-navy pt-48 pb-16 lg:pt-48 lg:pb-24 relative overflow-hidden bg-[url('/calculator.jpg')] bg-cover bg-[center_0%] bg-no-repeat">
        <!-- Capa oscura -->
        <div class="absolute inset-0 bg-black/76"></div>

      <!-- Decoración -->
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue/10 to-transparent pointer-events-none"></div>
      

      <div class="container relative z-10">
        <div class="max-w-2xl">
          <!-- <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue/10 border border-blue/20 text-blue text-sm font-bold uppercase tracking-widest mb-6">
            <Calculator size={14} />
            {t('calcPage.title')}
          </span> -->
          <h1 class="text-4xl lg:text-6xl font-secondary font-black text-white mb-6 tracking-tighter leading-tight">
            {t('calcPage.title')}
          </h1>
          <p class="text-white/60 text-lg lg:text-xl leading-relaxed font-light">
            {t('calcPage.description')}
          </p>
        </div>
      </div>
    </section>

    <!-- Calculator Section -->
    <section class="py-16 lg:py-28 bg-[#F7F8FA]">
      <div class="container">

        <!-- Calculator Card -->
        <div class="max-w-5xl mx-auto bg-white rounded-[40px] shadow-2xl shadow-black/5 border border-gray-100 overflow-hidden">

          <!-- Calculator Header -->
          <div class="bg-navy px-8 py-8 lg:px-12 lg:py-10 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-48 h-48 bg-blue/10 rounded-full blur-2xl pointer-events-none"></div>
            <div class="relative z-10 flex flex-col sm:flex-row sm:items-center gap-4">
              <div class="w-12 h-12 rounded-2xl bg-blue/20 border border-blue/30 flex items-center justify-center text-blue shrink-0">
                <TrendingDown size={22} />
              </div>
              <div>
                <span class="text-blue text-xs font-bold uppercase tracking-widest block mb-1">{t('calc.autoRefi.badge')}</span>
                <h2 class="text-2xl lg:text-3xl font-secondary font-black text-white leading-tight">
                  {t('calc.autoRefi.title')}
                </h2>
                <p class="text-white/50 text-sm mt-1 max-w-lg">{t('calc.autoRefi.subtitle')}</p>
              </div>
            </div>
          </div>

          <!-- Calculator Tabs Navigation -->
          <div class="flex flex-col sm:flex-row border-b border-gray-100 bg-navy p-2 gap-2">
            <button 
              id="tab-autoRefi" 
              class="flex-1 flex items-center justify-center gap-2 py-4 px-6 rounded-2xl font-bold text-sm transition-all duration-300 bg-white shadow-sm text-blue hover:bg-gray-100 cursor-pointer"
              data-tab="autoRefi"
            >
              <TrendingDown size={18} />
              {t('calc.tabs.autoRefi')}
            </button>
            <button 
              id="tab-homeLoan" 
              class="flex-1 flex items-center justify-center gap-2 py-4 px-6 rounded-2xl font-bold text-sm transition-all duration-300 text-gray-400 hover:bg-navy-light cursor-pointer"
              data-tab="homeLoan"
            >
              <PiggyBank size={18} />
              {t('calc.tabs.homeLoan')}
            </button>
          </div>

          <!-- Calculator Body -->
          <div class="p-8 lg:p-12">
            
            <!-- Tab 1: Refinanciamiento -->
            <div id="content-autoRefi" class="tab-content transition-all duration-500">
              <form id="autoRefiForm" class="space-y-10" novalidate>
                <!-- Inputs Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <!-- Pago Mensual Actual -->
                  <div class="input-group">
                    <label for="currentPayment" class="input-label">
                      {t('calc.autoRefi.input.currentPayment')}
                    </label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input
                        type="number"
                        id="currentPayment"
                        name="currentPayment"
                        min="0"
                        step="0.01"
                        placeholder="350.00"
                        class="calc-input"
                      />
                    </div>
                  </div>

                  <!-- Saldo Restante -->
                  <div class="input-group">
                    <label for="balance" class="input-label">
                      {t('calc.autoRefi.input.balance')}
                    </label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input
                        type="number"
                        id="balance"
                        name="balance"
                        min="0"
                        step="0.01"
                        placeholder="18,000.00"
                        class="calc-input"
                      />
                    </div>
                  </div>

                  <!-- APR Actual -->
                  <div class="input-group">
                    <label for="currentRate" class="input-label">
                      {t('calc.autoRefi.input.currentRate')}
                    </label>
                    <div class="input-wrapper">
                      <input
                        type="number"
                        id="currentRate"
                        name="currentRate"
                        min="0"
                        max="100"
                        step="0.01"
                        placeholder="8.5"
                        class="calc-input"
                      />
                      <span class="input-suffix">%</span>
                    </div>
                  </div>

                  <!-- Nuevo APR -->
                  <div class="input-group">
                    <label for="newRate" class="input-label">
                      {t('calc.autoRefi.input.newRate')}
                    </label>
                    <div class="input-wrapper">
                      <input
                        type="number"
                        id="newRate"
                        name="newRate"
                        min="0"
                        max="100"
                        step="0.01"
                        placeholder="4.5"
                        class="calc-input"
                      />
                      <span class="input-suffix">%</span>
                    </div>
                  </div>

                  <!-- Plazo Restante -->
                  <div class="input-group">
                    <label for="currentTerm" class="input-label">
                      {t('calc.autoRefi.input.currentTerm')}
                    </label>
                    <div class="input-wrapper">
                      <input
                        type="number"
                        id="currentTerm"
                        name="currentTerm"
                        min="0"
                        max="10"
                        step="1"
                        placeholder="4"
                        class="calc-input"
                      />
                      <span class="input-suffix">{lang === 'en' ? 'yrs' : 'años'}</span>
                    </div>
                  </div>

                  <!-- Nuevo Plazo -->
                  <div class="input-group">
                    <label for="newTerm" class="input-label">
                      {t('calc.autoRefi.input.newTerm')}
                    </label>
                    <div class="input-wrapper">
                      <input
                        type="number"
                        id="newTerm"
                        name="newTerm"
                        min="0"
                        max="10"
                        step="1"
                        placeholder="5"
                        class="calc-input"
                      />
                      <span class="input-suffix">{lang === 'en' ? 'yrs' : 'años'}</span>
                    </div>
                  </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4">
                  <button type="submit" id="calculateBtn" class="btn btn-primary flex-1 flex items-center justify-center gap-2 py-4 text-base">
                    <Calculator size={18} />
                    {t('calc.autoRefi.btnCalculate')}
                  </button>
                  <button type="reset" id="resetBtn" class="btn flex items-center justify-center gap-2 px-8 py-4 border border-gray-200 bg-white text-navy/70 hover:bg-gray-50 hover:border-gray-300 text-base rounded-2xl transition-all">
                    <RefreshCcw size={16} />
                    {t('calc.autoRefi.btnReset')}
                  </button>
                </div>

                <!-- Results -->
                <div id="resultsSection" class="space-y-6 transition-all duration-500">
                  <div class="h-px bg-gray-100"></div>
                  <h3 class="text-sm font-bold text-navy/50 uppercase tracking-widest">{lang === 'en' ? 'Your Results' : 'Tus Resultados'}</h3>

                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <!-- Nuevo Pago Mensual -->
                    <div class="result-card result-card--primary">
                      <div class="result-icon">
                        <DollarSign size={20} />
                      </div>
                      <span class="result-label">{t('calc.autoRefi.output.newPayment')}</span>
                      <span class="result-value" id="outputNewPayment">{t('calc.autoRefi.output.placeholder')}</span>
                    </div>

                    <!-- Ahorros Mensuales -->
                    <div class="result-card result-card--green">
                      <div class="result-icon">
                        <PiggyBank size={20} />
                      </div>
                      <span class="result-label">{t('calc.autoRefi.output.monthlySavings')}</span>
                      <span class="result-value" id="outputMonthlySavings">{t('calc.autoRefi.output.placeholder')}</span>
                    </div>

                    <!-- Ahorro de Intereses -->
                    <div class="result-card result-card--blue">
                      <div class="result-icon">
                        <TrendingDown size={20} />
                      </div>
                      <span class="result-label">{t('calc.autoRefi.output.interestSavings')}</span>
                      <span class="result-value" id="outputInterestSavings">{t('calc.autoRefi.output.placeholder')}</span>
                    </div>
                  </div>

                  <!-- CTA Quote Button -->
                  <div id="quoteSection" class="mt-2 p-6 rounded-3xl bg-gray-50 border border-gray-100">
                    <p class="text-navy/60 text-sm mb-4 text-center">
                      ¿Te gustan los números? Deja que uno de nuestros expertos te prepare una oferta real.
                    </p>
                    <button
                      type="button"
                      id="quoteBtn"
                      class="btn btn-primary w-full flex items-center justify-center gap-2 py-5 text-base font-bold"
                    >
                      <PiggyBank size={20} />
                      {t('calc.autoRefi.btnQuote')}
                    </button>
                  </div>

                  <!-- Disclaimer -->
                  <p class="text-xs text-gray-400 leading-relaxed">{t('calc.autoRefi.disclaimer')}</p>
                </div>
              </form>
            </div>

            <!-- Tab 2: Home Loan -->
            <div id="content-homeLoan" class="tab-content hidden transition-all duration-500">
              <form id="homeLoanForm" class="space-y-10" novalidate>
                <!-- Inputs Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <!-- Precio de la Casa -->
                  <div class="input-group">
                    <label for="homePrice" class="input-label">{t('calc.homeLoan.input.price')}</label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input type="number" id="homePrice" name="homePrice" min="0" step="1000" placeholder="350000" class="calc-input" />
                    </div>
                  </div>

                  <!-- Pago Inicial -->
                  <div class="input-group">
                    <label for="downPayment" class="input-label">{t('calc.homeLoan.input.downPayment')}</label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input type="number" id="downPayment" name="downPayment" min="0" step="1000" placeholder="70000" class="calc-input" />
                    </div>
                  </div>

                  <!-- Tasa de Interés -->
                  <div class="input-group">
                    <label for="interestRate" class="input-label">{t('calc.homeLoan.input.interestRate')}</label>
                    <div class="input-wrapper">
                      <input type="number" id="interestRate" name="interestRate" min="0" max="100" step="0.01" placeholder="6.5" class="calc-input" />
                      <span class="input-suffix">%</span>
                    </div>
                  </div>

                  <!-- Plazo del Préstamo -->
                  <div class="input-group">
                    <label for="loanTermYears" class="input-label">{t('calc.homeLoan.input.years')}</label>
                    <div class="input-wrapper">
                      <input type="number" id="loanTermYears" name="loanTermYears" min="1" max="50" step="1" placeholder="30" class="calc-input" />
                    </div>
                  </div>

                  <!-- Impuesto Predial -->
                  <div class="input-group">
                    <label for="propertyTaxYr" class="input-label">{t('calc.homeLoan.input.propertyTax')}</label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input type="number" id="propertyTaxYr" name="propertyTaxYr" min="0" step="0.01" placeholder="4200" class="calc-input" />
                    </div>
                  </div>

                  <!-- Seguro de Casa -->
                  <div class="input-group">
                    <label for="homeInsuranceYr" class="input-label">{t('calc.homeLoan.input.homeInsurance')}</label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input type="number" id="homeInsuranceYr" name="homeInsuranceYr" min="0" step="0.01" placeholder="1200" class="calc-input" />
                    </div>
                  </div>

                  <!-- PMI -->
                  <div class="input-group">
                    <label for="pmi" class="input-label">{t('calc.homeLoan.input.pmi')}</label>
                    <div class="input-wrapper">
                      <span class="input-prefix">$</span>
                      <input type="number" id="pmi" name="pmi" min="0" step="0.01" placeholder="150" class="calc-input" />
                    </div>
                  </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4">
                  <button type="submit" id="homeCalculateBtn" class="btn btn-primary flex-1 flex items-center justify-center gap-2 py-4 text-base">
                    <Calculator size={18} />
                    {t('calc.autoRefi.btnCalculate')}
                  </button>
                  <button type="reset" class="btn flex items-center justify-center gap-2 px-8 py-4 border border-gray-200 bg-white text-navy/70 hover:bg-gray-50 hover:border-gray-300 text-base rounded-2xl transition-all">
                    <RefreshCcw size={16} />
                    {t('calc.autoRefi.btnReset')}
                  </button>
                </div>

                <!-- Results -->
                <div id="homeResultsSection" class="space-y-6 pt-10 border-t border-gray-100">
                  <h3 class="text-sm font-bold text-navy/50 uppercase tracking-widest">{lang === 'en' ? 'Your Mortgage Results' : 'Tus Resultados Hipotecarios'}</h3>

                  <!-- Main Monthly Result -->
                  <div class="result-card result-card--primary p-8 text-center sm:text-left">
                    <div class="sm:flex items-center justify-between gap-6">
                      <div class="space-y-1 mb-4 sm:mb-0">
                        <span class="result-label block text-white/60">{t('calc.homeLoan.output.monthlyPayment')}</span>
                        <span class="text-4xl lg:text-5xl font-black text-white" id="outputHomeMonthlyPayment">--</span>
                      </div>
                      <div class="shrink-0">
                        <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/20 flex items-center justify-center text-white mx-auto sm:mx-0">
                          <DollarSign size={32} />
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Details Grid -->
                  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    <div class="p-5 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-1">
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{t('calc.homeLoan.output.principalInterest')}</span>
                      <span class="text-lg font-black text-navy" id="outputHomePI">--</span>
                    </div>
                    <div class="p-5 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-1">
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{t('calc.homeLoan.output.propertyTax')} (Mes)</span>
                      <span class="text-lg font-black text-navy" id="outputHomeTax">--</span>
                    </div>
                    <div class="p-5 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-1">
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{t('calc.homeLoan.output.homeInsurance')} (Mes)</span>
                      <span class="text-lg font-black text-navy" id="outputHomeInsurance">--</span>
                    </div>
                    <div class="p-5 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-1">
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{t('calc.homeLoan.output.loanAmount')}</span>
                      <span class="text-lg font-black text-navy" id="outputHomeLoanAmount">--</span>
                    </div>
                    <div class="p-5 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-1">
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{t('calc.homeLoan.output.totalInterest')}</span>
                      <span class="text-lg font-black text-navy text-blue" id="outputHomeTotalInterest">--</span>
                    </div>
                    <div class="p-5 rounded-2xl bg-gray-50 border border-gray-100 flex flex-col gap-1">
                      <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{t('calc.homeLoan.output.totalCost')}</span>
                      <span class="text-lg font-black text-navy" id="outputHomeTotalCost">--</span>
                    </div>
                  </div>

                  <!-- Quote CTA Button -->
                  <div class="mt-4 p-8 rounded-3xl bg-blue/5 border border-blue/10 text-center">
                    <p class="text-navy/70 text-sm mb-6 max-w-sm mx-auto">
                      Obtén una cotización hipotecaria real de nuestros expertos con licencia y asegura la casa de tus sueños a la mejor tasa posible.
                    </p>
                    <button id="homeQuoteBtn" class="btn btn-primary px-10 py-5 text-base font-bold inline-flex items-center gap-2">
                      <PiggyBank size={20} />
                      {t('calc.homeLoan.btnQuote')}
                    </button>
                  </div>

                  <p class="text-xs text-gray-400 leading-relaxed text-center">{t('calc.autoRefi.disclaimer')}</p>
                </div>
              </form>
            </div>

          </div>

        </div>
      </div>
    </section>
  </main>

  <!-- Modal de Cotización -->
  <div
    id="quoteModal"
    class="fixed inset-0 z-[999] flex items-center justify-center p-4 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="quoteModalTitle"
  >
    <!-- Fondo oscuro -->
    <div id="quoteModalBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative z-10 bg-white rounded-[28px] shadow-2xl w-full max-w-md overflow-hidden">
      <!-- Header -->
      <div class="bg-navy px-8 py-6 flex items-center justify-between">
        <div>
          <h3 id="quoteModalTitle" class="text-lg font-black text-white leading-tight">Obtén una Oferta Real</h3>
          <p class="text-white/40 text-xs mt-0.5">Te prepararemos una oferta personalizada con tus datos.</p>
        </div>
        <button id="quoteModalClose" class="text-white/40 hover:text-white transition-colors" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Body -->
      <div class="p-8 space-y-4">
        <!-- Chips de resumen -->
        <div class="flex flex-wrap gap-2 mb-2">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue/10 text-blue text-xs font-bold">
            Nuevo pago: <span id="modalNewPayment" class="font-black">—</span>
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green-50 text-green-700 text-xs font-bold">
            Ahorro mensual: <span id="modalMonthlySavings" class="font-black">—</span>
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue/10 text-blue text-xs font-bold">
            Interés ahorrado: <span id="modalInterestSavings" class="font-black">—</span>
          </span>
        </div>

        <form id="quoteForm" class="space-y-4" novalidate>
          <div>
            <label for="quoteName" class="block text-xs font-bold text-navy/60 uppercase tracking-wider mb-1.5">Nombre Completo <span class="text-red-500">*</span></label>
            <input id="quoteName" name="quoteName" type="text" required autocomplete="name"
              placeholder="Juan García"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue focus:ring-2 focus:ring-blue/20 outline-none transition text-navy text-sm font-medium bg-gray-50 focus:bg-white"
            />
          </div>
          <div>
            <label for="quoteEmail" class="block text-xs font-bold text-navy/60 uppercase tracking-wider mb-1.5">Correo Electrónico <span class="text-red-500">*</span></label>
            <input id="quoteEmail" name="quoteEmail" type="email" required autocomplete="email"
              placeholder="juan@ejemplo.com"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue focus:ring-2 focus:ring-blue/20 outline-none transition text-navy text-sm font-medium bg-gray-50 focus:bg-white"
            />
          </div>
          <div>
            <label for="quotePhone" class="block text-xs font-bold text-navy/60 uppercase tracking-wider mb-1.5">Teléfono (opcional)</label>
            <input id="quotePhone" name="quotePhone" type="tel" autocomplete="tel"
              placeholder="+1 (555) 000-0000"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue focus:ring-2 focus:ring-blue/20 outline-none transition text-navy text-sm font-medium bg-gray-50 focus:bg-white"
            />
          </div>

          <!-- Feedback -->
          <div id="quoteFeedback" class="hidden px-4 py-3 rounded-xl text-sm font-semibold text-center" role="alert"></div>

          <button type="submit" id="quoteSubmitBtn"
            class="btn btn-primary w-full flex items-center justify-center gap-2 py-4 text-sm font-bold mt-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            <span id="quoteSubmitText">Enviar Solicitud de Cotización</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Modal de Cotización Hipotecaria -->
  <div
    id="homeQuoteModal"
    class="fixed inset-0 z-[999] flex items-center justify-center p-4 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="homeQuoteModalTitle"
  >
    <!-- Fondo oscuro -->
    <div id="homeQuoteModalBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative z-10 bg-white rounded-[28px] shadow-2xl w-full max-w-md overflow-hidden">
      <!-- Header -->
      <div class="bg-navy px-8 py-6 flex items-center justify-between">
        <div>
          <h3 id="homeQuoteModalTitle" class="text-lg font-black text-white leading-tight">Obtén una Oferta Hipotecaria</h3>
          <p class="text-white/40 text-xs mt-0.5">Te prepararemos una oferta personalizada con tus datos.</p>
        </div>
        <button id="homeQuoteModalClose" class="text-white/40 hover:text-white transition-colors" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Body -->
      <div class="p-8 space-y-4">
        <!-- Chips de resumen -->
        <div class="flex flex-wrap gap-2 mb-2">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue/10 text-blue text-xs font-bold">
            Pago Mensual: <span id="modalHomeMonthly" class="font-black">—</span>
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-gray-100 text-navy text-xs font-bold">
            Préstamo: <span id="modalHomeLoan" class="font-black">—</span>
          </span>
        </div>

        <form id="homeQuoteForm" class="space-y-4" novalidate>
          <div>
            <label for="homeQuoteName" class="block text-xs font-bold text-navy/60 uppercase tracking-wider mb-1.5">Nombre Completo <span class="text-red-500">*</span></label>
            <input id="homeQuoteName" name="homeQuoteName" type="text" required autocomplete="name"
              placeholder="Juan García"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue focus:ring-2 focus:ring-blue/20 outline-none transition text-navy text-sm font-medium bg-gray-50 focus:bg-white"
            />
          </div>
          <div>
            <label for="homeQuoteEmail" class="block text-xs font-bold text-navy/60 uppercase tracking-wider mb-1.5">Correo Electrónico <span class="text-red-500">*</span></label>
            <input id="homeQuoteEmail" name="homeQuoteEmail" type="email" required autocomplete="email"
              placeholder="juan@ejemplo.com"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue focus:ring-2 focus:ring-blue/20 outline-none transition text-navy text-sm font-medium bg-gray-50 focus:bg-white"
            />
          </div>
          <div>
            <label for="homeQuotePhone" class="block text-xs font-bold text-navy/60 uppercase tracking-wider mb-1.5">Teléfono (opcional)</label>
            <input id="homeQuotePhone" name="homeQuotePhone" type="tel" autocomplete="tel"
              placeholder="+1 (555) 000-0000"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue focus:ring-2 focus:ring-blue/20 outline-none transition text-navy text-sm font-medium bg-gray-50 focus:bg-white"
            />
          </div>

          <!-- Feedback -->
          <div id="homeQuoteFeedback" class="hidden px-4 py-3 rounded-xl text-sm font-semibold text-center" role="alert"></div>

          <button type="submit" id="homeQuoteSubmitBtn"
            class="btn btn-primary w-full flex items-center justify-center gap-2 py-4 text-sm font-bold mt-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            <span id="homeQuoteSubmitText">Enviar Solicitud de Cotización</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <Footer />
</MainLayout>

<script>
  import { calculateAutoRefinance, calculateMortgage } from '../../utils/calculatorLogic';

  document.addEventListener('astro:page-load', () => {
    // --- Tabs Logic ---
    const tabs = document.querySelectorAll('[data-tab]');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        
        // Estilos de pestañas
        tabs.forEach(t => {
          t.classList.remove('bg-white', 'shadow-sm', 'text-blue');
          t.classList.add('text-gray-400');
        });
        tab.classList.add('bg-white', 'shadow-sm', 'text-blue');
        tab.classList.remove('text-gray-400');

        // Visibilidad de contenido
        contents.forEach(content => {
          if (content.id === `content-${target}`) {
            content.classList.remove('hidden');
          } else {
            content.classList.add('hidden');
          }
        });
      });
    });

    const form = document.getElementById('autoRefiForm') as HTMLFormElement;
    if (!form || form.dataset.initialized) return; // guard against double init
    form.dataset.initialized = 'true';

    const outputs = {
      newPayment: document.getElementById('outputNewPayment'),
      monthlySavings: document.getElementById('outputMonthlySavings'),
      interestSavings: document.getElementById('outputInterestSavings')
    };

    const formatCurrency = (val: number) => {
      return new Intl.NumberFormat('es-US', {
        style: 'currency',
        currency: 'USD',
      }).format(val);
    };

    // Guardar últimos resultados para el modal
    let lastInputs  = { currentPayment: 0, balance: 0, currentRate: 0, newRate: 0, currentTerm: 0, newTerm: 0 };
    let lastResults = { newMonthlyPayment: 0, monthlySavings: 0, totalInterestSaved: 0 };

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      lastInputs = {
        currentPayment: Number(formData.get('currentPayment')) || 0,
        balance:        Number(formData.get('balance'))        || 0,
        currentRate:    Number(formData.get('currentRate'))    || 0,
        newRate:        Number(formData.get('newRate'))        || 0,
        currentTerm:    Number(formData.get('currentTerm'))    || 0,
        newTerm:        Number(formData.get('newTerm'))        || 0,
      };

      const result = calculateAutoRefinance(lastInputs);
      lastResults = {
        newMonthlyPayment:  result.newMonthlyPayment,
        monthlySavings:     result.monthlySavings,
        totalInterestSaved: result.totalInterestSaved,
      };

      if (outputs.newPayment)      outputs.newPayment.textContent      = formatCurrency(result.newMonthlyPayment);
      if (outputs.monthlySavings)  outputs.monthlySavings.textContent  = formatCurrency(result.monthlySavings);
      if (outputs.interestSavings) outputs.interestSavings.textContent = formatCurrency(result.totalInterestSaved);

      const resultCards = document.querySelectorAll('.result-card');
      resultCards.forEach(card => {
        card.classList.add('scale-105', 'ring-2', 'ring-blue/20');
        setTimeout(() => card.classList.remove('scale-105', 'ring-2', 'ring-blue/20'), 300);
      });
    });

    // Resetear
    form.addEventListener('reset', () => {
      Object.values(outputs).forEach(out => { if (out) out.textContent = '--'; });
      lastInputs  = { currentPayment: 0, balance: 0, currentRate: 0, newRate: 0, currentTerm: 0, newTerm: 0 };
      lastResults = { newMonthlyPayment: 0, monthlySavings: 0, totalInterestSaved: 0 };
    });

    // ── Modal de Cotización ───────────────────────────────────────────────
    const quoteBtn       = document.getElementById('quoteBtn');
    const quoteModal     = document.getElementById('quoteModal');
    const quoteBackdrop  = document.getElementById('quoteModalBackdrop');
    const quoteClose     = document.getElementById('quoteModalClose');
    const quoteForm      = document.getElementById('quoteForm')      as HTMLFormElement;
    const quoteSubmitBtn = document.getElementById('quoteSubmitBtn') as HTMLButtonElement;
    const quoteSubmitTxt = document.getElementById('quoteSubmitText');
    const quoteFeedback  = document.getElementById('quoteFeedback');

    const modalNewPayment      = document.getElementById('modalNewPayment');
    const modalMonthlySavings  = document.getElementById('modalMonthlySavings');
    const modalInterestSavings = document.getElementById('modalInterestSavings');

    function openModal() {
      if (lastResults.newMonthlyPayment === 0) {
        alert('Primero calcula los resultados de tu refinanciamiento.');
        return;
      }
      if (modalNewPayment)      modalNewPayment.textContent      = formatCurrency(lastResults.newMonthlyPayment);
      if (modalMonthlySavings)  modalMonthlySavings.textContent  = formatCurrency(lastResults.monthlySavings);
      if (modalInterestSavings) modalInterestSavings.textContent = formatCurrency(lastResults.totalInterestSaved);

      quoteModal?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      quoteModal?.classList.add('hidden');
      document.body.style.overflow = '';
      quoteFeedback?.classList.add('hidden');
      quoteForm?.reset();
    }

    quoteBtn?.addEventListener('click', openModal);
    quoteClose?.addEventListener('click', closeModal);
    quoteBackdrop?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    function showQuoteFeedback(success: boolean, msg: string) {
      if (!quoteFeedback) return;
      quoteFeedback.textContent = msg;
      quoteFeedback.className = 'px-4 py-3 rounded-xl text-sm font-semibold text-center';
      quoteFeedback.classList.add(
        success ? 'bg-green-50' : 'bg-red-50',
        success ? 'text-green-700' : 'text-red-700'
      );
    }

    quoteForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name  = (document.getElementById('quoteName')  as HTMLInputElement).value.trim();
      const email = (document.getElementById('quoteEmail') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('quotePhone') as HTMLInputElement).value.trim();

      if (!name || !email) {
        showQuoteFeedback(false, 'Por favor ingresa tu nombre y correo electrónico.');
        return;
      }

      quoteSubmitBtn.disabled = true;
      if (quoteSubmitTxt) quoteSubmitTxt.textContent = 'Enviando…';

      try {
        const res  = await fetch('/send_quote.php', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            fullName: name,
            email,
            phone,
            ...lastInputs,
            ...lastResults,
          }),
        });

        const json = await res.json();

        if (res.ok && json.success) {
          showQuoteFeedback(true, '✅ ¡Solicitud enviada! Nuestro equipo se pondrá en contacto pronto.');
          quoteForm.reset();
          setTimeout(closeModal, 3000);
        } else {
          showQuoteFeedback(false, json.message || 'Algo salió mal. Por favor intenta de nuevo.');
        }
      } catch {
        showQuoteFeedback(false, 'Error de red. Por favor intenta de nuevo.');
      } finally {
        quoteSubmitBtn.disabled = false;
        if (quoteSubmitTxt) quoteSubmitTxt.textContent = 'Enviar Solicitud de Cotización';
      }
    });

    // --- Home Loan Logic ---
    let lastHomeInputs = { homePrice: 0, downPayment: 0, loanTermYears: 30, annualRate: 0, annualPropertyTax: 0, annualHomeInsurance: 0, monthlyPMI: 0 };
    let lastHomeResults = { loanAmount: 0, principalAndInterest: 0, monthlyPropertyTax: 0, monthlyHomeInsurance: 0, totalMonthlyPayment: 0, totalInterest: 0, totalCost: 0 };

    const homeForm = document.getElementById('homeLoanForm') as HTMLFormElement;
    if (homeForm) {
      const homeOutputs = {
        monthlyPayment: document.getElementById('outputHomeMonthlyPayment'),
        pi: document.getElementById('outputHomePI'),
        tax: document.getElementById('outputHomeTax'),
        insurance: document.getElementById('outputHomeInsurance'),
        loanAmount: document.getElementById('outputHomeLoanAmount'),
        totalInterest: document.getElementById('outputHomeTotalInterest'),
        totalCost: document.getElementById('outputHomeTotalCost')
      };

      homeForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(homeForm);
        
        lastHomeInputs = {
          homePrice: Number(fd.get('homePrice')) || 0,
          downPayment: Number(fd.get('downPayment')) || 0,
          loanTermYears: Number(fd.get('loanTermYears')) || 30,
          annualRate: Number(fd.get('interestRate')) || 0,
          annualPropertyTax: Number(fd.get('propertyTaxYr')) || 0,
          annualHomeInsurance: Number(fd.get('homeInsuranceYr')) || 0,
          monthlyPMI: Number(fd.get('pmi')) || 0,
        };

        lastHomeResults = calculateMortgage(lastHomeInputs);
        const res = lastHomeResults;

        if (homeOutputs.monthlyPayment) homeOutputs.monthlyPayment.textContent = formatCurrency(res.totalMonthlyPayment);
        if (homeOutputs.pi) homeOutputs.pi.textContent = formatCurrency(res.principalAndInterest);
        if (homeOutputs.tax) homeOutputs.tax.textContent = formatCurrency(res.monthlyPropertyTax);
        if (homeOutputs.insurance) homeOutputs.insurance.textContent = formatCurrency(res.monthlyHomeInsurance);
        if (homeOutputs.loanAmount) homeOutputs.loanAmount.textContent = formatCurrency(res.loanAmount);
        if (homeOutputs.totalInterest) homeOutputs.totalInterest.textContent = formatCurrency(res.totalInterest);
        if (homeOutputs.totalCost) homeOutputs.totalCost.textContent = formatCurrency(res.totalCost);

        const section = document.getElementById('homeResultsSection');
        section?.classList.add('scale-[1.01]', 'brightness-105');
        setTimeout(() => section?.classList.remove('scale-[1.01]', 'brightness-105'), 200);
      });

      homeForm.addEventListener('reset', () => {
        Object.values(homeOutputs).forEach(out => { if (out) out.textContent = '--'; });
        lastHomeInputs = { homePrice: 0, downPayment: 0, loanTermYears: 30, annualRate: 0, annualPropertyTax: 0, annualHomeInsurance: 0, monthlyPMI: 0 };
        lastHomeResults = { loanAmount: 0, principalAndInterest: 0, monthlyPropertyTax: 0, monthlyHomeInsurance: 0, totalMonthlyPayment: 0, totalInterest: 0, totalCost: 0 };
      });
    }

    // --- Modal de Cotización Hipotecaria ─────────────────────────────────────
    const hQuoteBtn       = document.getElementById('homeQuoteBtn');
    const hQuoteModal     = document.getElementById('homeQuoteModal');
    const hQuoteBackdrop  = document.getElementById('homeQuoteModalBackdrop');
    const hQuoteClose     = document.getElementById('homeQuoteModalClose');
    const hQuoteForm      = document.getElementById('homeQuoteForm')      as HTMLFormElement;
    const hQuoteSubmitBtn = document.getElementById('homeQuoteSubmitBtn') as HTMLButtonElement;
    const hQuoteSubmitTxt = document.getElementById('homeQuoteSubmitText');
    const hQuoteFeedback  = document.getElementById('homeQuoteFeedback');

    const modalHomeMonthly = document.getElementById('modalHomeMonthly');
    const modalHomeLoan    = document.getElementById('modalHomeLoan');

    function openHomeModal() {
      if (lastHomeResults.totalMonthlyPayment === 0) {
        alert('Por favor calcula tus resultados hipotecarios primero.');
        return;
      }
      if (modalHomeMonthly) modalHomeMonthly.textContent = formatCurrency(lastHomeResults.totalMonthlyPayment);
      if (modalHomeLoan)    modalHomeLoan.textContent    = formatCurrency(lastHomeResults.loanAmount);

      hQuoteModal?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeHomeModal() {
      hQuoteModal?.classList.add('hidden');
      document.body.style.overflow = '';
      hQuoteFeedback?.classList.add('hidden');
      hQuoteForm?.reset();
    }

    hQuoteBtn?.addEventListener('click', (e) => { e.preventDefault(); openHomeModal(); });
    hQuoteClose?.addEventListener('click', closeHomeModal);
    hQuoteBackdrop?.addEventListener('click', closeHomeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeHomeModal(); });

    function showHQuoteFeedback(success: boolean, msg: string) {
      if (!hQuoteFeedback) return;
      hQuoteFeedback.textContent = msg;
      hQuoteFeedback.className = 'px-4 py-3 rounded-xl text-sm font-semibold text-center';
      hQuoteFeedback.classList.add(
        success ? 'bg-green-50' : 'bg-red-50',
        success ? 'text-green-700' : 'text-red-700'
      );
    }

    hQuoteForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name  = (document.getElementById('homeQuoteName')  as HTMLInputElement).value.trim();
      const email = (document.getElementById('homeQuoteEmail') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('homeQuotePhone') as HTMLInputElement).value.trim();

      if (!name || !email) {
        showHQuoteFeedback(false, 'Por favor ingresa tu nombre y correo electrónico.');
        return;
      }

      hQuoteSubmitBtn.disabled = true;
      if (hQuoteSubmitTxt) hQuoteSubmitTxt.textContent = 'Enviando…';

      try {
        const res  = await fetch('/send_home_quote.php', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            fullName: name,
            email,
            phone,
            ...lastHomeInputs,
            ...lastHomeResults,
          }),
        });

        const json = await res.json();

        if (res.ok && json.success) {
          showHQuoteFeedback(true, '✅ ¡Solicitud enviada! Nuestro equipo se pondrá en contacto pronto.');
          hQuoteForm.reset();
          setTimeout(closeHomeModal, 3000);
        } else {
          showHQuoteFeedback(false, json.message || 'Algo salió mal. Por favor intenta de nuevo.');
        }
      } catch {
        showHQuoteFeedback(false, 'Error de red. Por favor intenta de nuevo.');
      } finally {
        hQuoteSubmitBtn.disabled = false;
        if (hQuoteSubmitTxt) hQuoteSubmitTxt.textContent = 'Enviar Solicitud de Cotización';
      }
    });
  });
</script>

