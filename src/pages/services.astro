---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getServicesData } from '../data/services';


const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const services = getServicesData(t);
---

<MainLayout title={`${t('servicesPage.title')} | DRIVE POINT SOLUTIONS`}>
  <Navbar />
  
  <main>
    <!-- Hero Section -->
    <section class="pt-32 pb-20 lg:pt-48 lg:pb-32 relative overflow-hidden bg-[url('/hero-service.jpg')] bg-cover bg-[center_0%] bg-no-repeat">
      <!-- Decoración de fondo -->
      <!-- <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue/10 to-transparent pointer-events-none"></div> -->

        <!-- Capa oscura -->
      <div class="absolute inset-0 bg-black/60"></div>

      <!-- Decoración -->
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue/10 to-transparent pointer-events-none"></div>
      
      <div class="container relative z-10">
        <div class="max-w-3xl">
          <!-- <h1 class="text-4xl lg:text-7xl font-secondary font-black text-white mb-8 tracking-tighter leading-tight" style="view-transition-name: page-title">
            {t('servicesPage.title')}
          </h1> -->
          <h1
            class="text-4xl lg:text-7xl font-secondary font-black text-white mb-8 tracking-tighter leading-tight"
            style="view-transition-name: page-title"
          >
            {t('servicesPage.title').split('\n').map((line, i) => (
              <>
                {line}
                {i < t('servicesPage.title').split('\n').length - 1 && <br />}
              </>
            ))}
          </h1>
          <p class="text-white/60 text-lg lg:text-2xl leading-relaxed font-light">
            {t('servicesPage.description')}
          </p>
        </div>
      </div>
    </section>

    <!-- Services Explorer -->
    <section class="py-20 lg:py-40 bg-white">
      <div class="container">
        <div class="space-y-32 lg:space-y-56">
          {services.map((service, index) => {
            const Icon = service.icon;
            return (
              <div class={`flex flex-col lg:flex-row gap-16 lg:gap-24 items-center ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
                <!-- Visual Area -->
                <div class="w-full lg:w-3/5 group">
                  <div class="relative aspect-[16/10] overflow-hidden rounded-[40px] bg-gray-50 border border-gray-100 shadow-2xl shadow-black/5 transition-transform duration-500 group-hover:scale-[1.02]">
                    <!-- Background Image -->
                    <div 
                      class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
                      style={`background-image: url('${service.bgImage}');`}
                    ></div>

                    <!-- Icon Placeholder -->
                    <div class="absolute inset-0 flex flex-col items-center justify-center bg-navy/20 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                      <div class="text-white drop-shadow-2xl">
                        <Icon size={64} strokeWidth={1.5} />
                      </div>
                    </div>
                    
                    <!-- Decorative overlay -->
                    <div class="absolute inset-0 bg-gradient-to-br from-blue/10 to-transparent pointer-events-none"></div>
                  </div>
                </div>

                <!-- Information Area -->
                <div class="w-full lg:w-2/5 space-y-8">
                  <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-blue/5 text-blue text-sm font-bold uppercase tracking-wider">
                    <Icon size={18} />
                    <span>{service.title}</span>
                  </div>
                  
                  <h2 class="text-3xl lg:text-5xl font-secondary font-black text-navy leading-tight">
                    {service.title}
                  </h2>
                  
                  <p class="text-gray-500 text-lg lg:text-xl leading-relaxed">
                    {service.desc}
                  </p>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
                    {service.features.map(feature => (
                      <div class="flex items-center gap-3 p-4 rounded-2xl bg-gray-50 border border-gray-100 transition-colors hover:bg-white hover:border-blue/20 hover:shadow-lg hover:shadow-blue/5">
                        <div class="w-2 h-2 rounded-full bg-blue shrink-0"></div>
                        <span class="text-sm font-semibold text-navy/80">{feature}</span>
                      </div>
                    ))}
                  </div>

                  <div class="pt-8">
                    <a href="/#contact" class="btn btn-primary shadow-xl shadow-blue/20 px-10 py-4 text-lg">
                      {lang === 'en' ? 'Get Started' : 'Empezar ahora'}
                    </a>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="pb-20 lg:pb-40 bg-white">
      <div class="container">
        <div class="bg-navy rounded-[50px] p-12 lg:p-24 text-center relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-blue/20 to-transparent pointer-events-none"></div>
          
          <h2 class="text-3xl lg:text-5xl font-secondary font-black text-white mb-8 relative z-10 leading-tight">
            {lang === 'en' ? 'Need a Custom Solution?' : '¿Necesitas una solución a medida?'}
          </h2>
          <p class="text-white/60 text-lg lg:text-xl mb-12 max-w-2xl mx-auto relative z-10">
            {lang === 'en' ? 'Our experts are ready to help you find the best path for your financial stability.' : 'Nuestros expertos están listos para ayudarte a encontrar el mejor camino para tu estabilidad financiera.'}
          </p>
          <a href="/#contact" class="btn btn-primary px-12 py-5 text-xl relative z-10">
            {lang === 'en' ? 'Contact an Expert' : 'Habla con un experto'}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>

<style>
  /* Animación suave para la entrada de elementos */
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .container > div > div {
    animation: fade-up 0.8s ease-out forwards;
  }
</style>
