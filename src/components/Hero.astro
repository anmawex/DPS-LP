---
---

<header class="relative h-screen min-h-[700px] flex items-center bg-[url('/hero-bg.png')] bg-cover bg-center text-white overflow-hidden pt-64 md:pt-20">
  <div class="absolute inset-0 bg-gradient-to-tr from-navy/95 via-navy/70 to-navy/30 z-1"></div>
  
  <div class="container relative z-10 grid lg:grid-cols-[1.2fr_0.8fr] items-center gap-16">
    <div class="max-w-3xl animate-fade-in">
      <div class="mb-6">
        <span class="inline-block px-5 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-sm font-semibold text-blue tracking-wide">
          Préstamos & Refinanciamiento
        </span>
      </div>
      
      <h1 class="text-5xl lg:text-7xl mb-6 leading-[0.9] tracking-tight font-extrabold">
        Impulsa tus sueños con <span class="text-gradient">Financiamiento Inteligente</span>
      </h1>
      
      <p class="text-xl mb-10 opacity-85 max-w-xl leading-relaxed">
        Entendemos que tu tiempo y dinero son valiosos. Ofrecemos soluciones rápidas y personalizadas para el auto que deseas o el hogar que ya tienes.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a href="#contact" class="btn btn-primary btn-glow px-8 py-4 text-sm tracking-widest uppercase">
          Aplicar Ahora
        </a>
        <a href="#services" class="btn bg-white/5 backdrop-blur-md border border-white/30 text-white hover:bg-white hover:text-navy px-8 py-4 text-sm tracking-widest uppercase">
          Explorar Servicios
        </a>
      </div>

      <div class="flex flex-wrap gap-8 animate-slide-up">
        <div class="flex items-center gap-4 bg-white/5 backdrop-blur-lg p-4 rounded-2xl border border-white/10 hover:bg-white/10 transition-colors">
          <span class="text-3xl">⭐</span>
          <div class="flex flex-col">
            <strong class="text-2xl leading-none">4.9/5</strong>
            <span class="text-[10px] uppercase tracking-widest opacity-60">Satisfacción</span>
          </div>
        </div>
        <div class="flex items-center gap-4 bg-white/5 backdrop-blur-lg p-4 rounded-2xl border border-white/10 hover:bg-white/10 transition-colors">
          <span class="text-3xl">⚡</span>
          <div class="flex flex-col">
            <strong class="text-2xl leading-none">24h</strong>
            <span class="text-[10px] uppercase tracking-widest opacity-60">Aprobación</span>
          </div>
        </div>
        <div class="flex items-center gap-4 bg-white/5 backdrop-blur-lg p-4 rounded-2xl border border-white/10 hover:bg-white/10 transition-colors">
          <span class="text-3xl">🤝</span>
          <div class="flex flex-col">
            <strong class="text-2xl leading-none">+10k</strong>
            <span class="text-[10px] uppercase tracking-widest opacity-60">Clientes</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Floating visual element -->
    <div class="hidden lg:flex justify-center relative animate-float">
      <div class="bg-white/10 backdrop-blur-2xl border border-white/20 p-8 rounded-[2rem] w-[320px] shadow-2xl">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-2 h-2 bg-green-500 rounded-full shadow-[0_0_10px_#2ecc71]"></div>
          <span class="text-xs font-semibold opacity-80">Aprobación En Línea</span>
        </div>
        <div class="space-y-3 mb-8">
          <div class="h-2 bg-white/10 rounded-full w-3/5"></div>
          <div class="h-2 bg-white/10 rounded-full w-4/5"></div>
          <div class="h-2 bg-white/10 rounded-full w-2/5"></div>
        </div>
        <div class="bg-green-500/20 text-green-400 text-center py-2.5 rounded-xl font-bold text-sm">
          Verificado ✓
        </div>
      </div>
      
      <!-- Secondary overlap element -->
      <div class="absolute -bottom-10 -left-10 bg-blue/20 backdrop-blur-xl border border-white/20 p-6 rounded-2xl shadow-xl animate-pulse">
        <div class="text-xs font-bold uppercase tracking-widest mb-1 opacity-70">Tasa Interés</div>
        <div class="text-3xl font-extrabold text-blue">4.5% APR</div>
      </div>
    </div>
  </div>
</header>

<style>
  .btn-glow {
    box-shadow: 0 0 20px rgba(46, 134, 222, 0.3);
  }
  .btn-glow:hover {
    box-shadow: 0 0 30px rgba(46, 134, 222, 0.5);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }

  .animate-fade-in { animation: fadeIn 1s ease-out forwards; }
  .animate-slide-up { animation: fadeIn 1s ease-out 0.3s forwards; opacity: 0; }
  .animate-float { animation: float 6s ease-in-out infinite; }
</style>
