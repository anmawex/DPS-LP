---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
import { Menu, X } from "lucide-astro";

---

<header id="navbar" class="fixed w-full top-0 z-50 bg-transparent border-b border-black/5 transition-all duration-300">
  <div class="container h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="relative z-50 font-secondary font-extrabold text-2xl text-navy tracking-tighter shadow-none">
      <span class="text-blue">DPS</span>
    </a>

    <!-- Botón Menú Móvil -->
    <button id="mobile-menu-btn" class="md:hidden z-50">
      <Menu id="icon-menu" class="w-7 h-7 text-white" />
      <X id="icon-close" class="w-7 h-7 text-white hidden" />
    </button>

    <!-- Navegación y Botón (Mobile First) -->
    <nav id="mobile-menu" class="fixed inset-0 z-40 bg-white/98 backdrop-blur-2xl flex flex-col justify-center items-center gap-8 pt-20 px-6 -translate-y-full opacity-0 pointer-events-none transition-all duration-400 ease-in-out md:static md:z-auto md:bg-transparent md:backdrop-blur-none md:flex-row md:justify-end md:gap-8 md:pt-0 md:px-0 md:translate-y-0 md:opacity-100 md:pointer-events-auto">
      
      <ul class="flex flex-col md:flex-row items-center gap-6 md:gap-8 w-full md:w-auto text-center">
        <li><a href="#services" class="text-navy hover:text-blue font-medium text-2xl md:text-base transition-colors menu-link">{t('nav.services')}</a></li>
        <li><a href="#benefits" class="text-navy hover:text-blue font-medium text-2xl md:text-base transition-colors menu-link">{t('nav.benefits')}</a></li>
        <li><a href="#reviews" class="text-navy hover:text-blue font-medium text-2xl md:text-base transition-colors menu-link">{t('nav.reviews')}</a></li>
      </ul>
      
      <div class="mt-4 md:mt-0 w-full max-w-[300px] md:max-w-none md:w-auto flex flex-col md:flex-row items-center justify-center gap-4">
        <a href={lang === 'en' ? '/es' : '/'} class="text-sm font-semibold text-navy/70 hover:text-blue border border-navy/20 px-3 py-1 rounded-full transition-colors order-2 md:order-1">
          {lang === 'en' ? 'ES' : 'EN'}
        </a>
        <a href="#contact" class="btn btn-accent w-full md:w-auto px-8 py-3.5 md:py-2.5 text-lg md:text-base menu-link order-1 md:order-2">{t('nav.apply')}</a>
      </div>
      
    </nav>
  </div>
</header>

<script>
  // Lógica del menú móvil ejecutada en el cliente
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const lines = btn?.querySelectorAll('span');
  let isMenuOpen = false;

  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;

    // Toggle de las clases principales del menú
    menu?.classList.toggle('-translate-y-full');
    menu?.classList.toggle('opacity-0');
    menu?.classList.toggle('pointer-events-none');
    document.body.classList.toggle('overflow-hidden');

    // Animación del ícono hamburguesa a una "X"
    if (lines && lines.length === 3) {
      if (isMenuOpen) {
        lines[0].classList.add('translate-y-2', 'rotate-45');
        lines[1].classList.add('opacity-0');
        lines[2].classList.add('-translate-y-2', '-rotate-45');
      } else {
        lines[0].classList.remove('translate-y-2', 'rotate-45');
        lines[1].classList.remove('opacity-0');
        lines[2].classList.remove('-translate-y-2', '-rotate-45');
      }
    }

    updateMenuColor();
  };

  // Event listener para el botón
  btn?.addEventListener('click', toggleMenu);

  // Cerrar el menú al hacer clic en cualquier enlace (solo si está abierto en mobile)
  document.querySelectorAll('.menu-link').forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen && window.innerWidth < 768) {
        toggleMenu();
      }
    });
  });

  // Asegurarnos de restaurar el scroll si se redimensiona la pantalla a desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isMenuOpen) {
      toggleMenu();
    }
  });

const navbar = document.getElementById("navbar");

window.addEventListener("scroll", () => {
  if (window.scrollY > 100) {
    navbar.classList.remove("bg-transparent");
    navbar.classList.add("bg-white/95", "shadow-lg");
  } else {
    navbar.classList.remove("bg-white/95", "shadow-lg");
    navbar.classList.add("bg-transparent");
  }
});

const menuIcon = document.getElementById("icon-menu");
const closeIcon = document.getElementById("icon-close");

const updateMenuColor = () => {
  if (isMenuOpen) {
    // menú abierto = X azul
    menuIcon?.classList.add("hidden");

    closeIcon?.classList.remove("hidden", "text-white", "text-navy");
    closeIcon?.classList.add("text-blue");

  } else {
    // menú cerrado
    closeIcon?.classList.add("hidden");

    menuIcon?.classList.remove("hidden", "text-blue");

    if (window.scrollY > 100) {
      // scroll activo
      menuIcon?.classList.remove("text-white");
      menuIcon?.classList.add("text-navy");
    } else {
      // estado inicial
      menuIcon?.classList.remove("text-navy");
      menuIcon?.classList.add("text-white");
    }
  }
};
</script>
