---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Logo from "../assets/DPS-logo.svg"

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
import { Menu, X } from "lucide-astro";

---

<header id="navbar" class="fixed w-full top-0 z-50 bg-transparent transition-all duration-300">
  <div class="container h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href={lang === 'en' ? '/' : '/es'} class="relative z-50 font-secondary font-extrabold text-2xl text-navy tracking-tighter shadow-none">
      <!-- <span class="text-blue">DPS</span> -->
       <Logo id="logo-navbar" class="w-24 h-24 text-white/85" />
    </a>

    <!-- Botón Menú Móvil -->
    <button id="mobile-menu-btn" class="lg:hidden z-50">
      <Menu id="icon-menu" class="w-7 h-7 text-white" />
      <X id="icon-close" class="w-7 h-7 text-white hidden" />
    </button>

    <!-- Navegación y Botón (Mobile First) -->
    <nav id="mobile-menu" class="fixed inset-0 z-40 bg-white/98 backdrop-blur-2xl flex flex-col justify-center items-center gap-8 pt-20 px-6 -translate-y-full opacity-0 pointer-events-none transition-all duration-400 ease-in-out lg:static lg:z-auto lg:bg-transparent lg:backdrop-blur-none lg:flex-row lg:justify-end lg:gap-8 lg:pt-0 lg:px-0 lg:translate-y-0 lg:opacity-100 lg:pointer-events-auto">
      
      <ul class="flex flex-col lg:flex-row items-center gap-6 lg:gap-8 w-full lg:w-auto text-center">
        <li><a href={lang === 'en' ? '/services' : '/es/services'} class="nav-link text-navy lg:text-white font-medium text-2xl lg:text-base transition-colors menu-link">{t('nav.services')}</a></li>
        <li><a href={lang === 'en' ? '/#benefits' : '/es#benefits'} class="nav-link text-navy lg:text-white font-medium text-2xl lg:text-base transition-colors menu-link">{t('nav.benefits')}</a></li>
        <!-- <li><a href="#reviews" class="text-navy hover:text-white font-medium text-2xl lg:text-base transition-colors menu-link">{t('nav.reviews')}</a></li> -->
        <li><a href={lang === 'en' ? '/#benefits' : '/es#benefits'} class="nav-link text-navy lg:text-white font-medium text-2xl lg:text-base transition-colors menu-link">{t('nav.calculators')}</a></li>
        <li><a href={lang === 'en' ? '/#contact' : '/es#contact'} class="nav-link text-navy lg:text-white font-medium text-2xl lg:text-base transition-colors menu-link">{t('nav.contact')}</a></li>
      </ul>
      
      <div class="mt-4 lg:mt-0 w-full max-w-[300px] lg:max-w-none lg:w-auto flex flex-col lg:flex-row items-center justify-center gap-4">
        <a href={lang === 'en' ? '/es' : '/'} class="nav-link text-navy lg:text-white text-sm font-semibold hover:text-white border border-gray-400 px-3 py-1 rounded-full transition-colors order-2 lg:order-1">
          {lang === 'en' ? 'ES' : 'EN'}
        </a>
        <!-- <a href="#contact" class="btn btn-accent w-full lg:w-auto px-8 py-3.5 lg:py-2.5 text-lg lg:text-base menu-link order-1 lg:order-2">{t('nav.apply')}</a> -->
      </div>
      
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    // Lógica del menú móvil ejecutada en el cliente
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const lines = btn?.querySelectorAll('span');
    let isMenuOpen = false;

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;

      menu?.classList.toggle('-translate-y-full');
      menu?.classList.toggle('opacity-0');
      menu?.classList.toggle('pointer-events-none');
      document.body.classList.toggle('overflow-hidden');

      if (lines && lines.length === 3) {
        if (isMenuOpen) {
          lines[0].classList.add('translate-y-2', 'rotate-45');
          lines[1].classList.add('opacity-0');
          lines[2].classList.add('-translate-y-2', '-rotate-45');
        } else {
          lines[0].classList.remove('translate-y-2', 'rotate-45');
          lines[1].classList.remove('opacity-0');
          lines[2].classList.remove('-translate-y-2', '-rotate-45');
        }
      }

      updateMenuColor();
    };

    btn?.addEventListener('click', toggleMenu);

    document.querySelectorAll('.menu-link').forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen && window.innerWidth < 1024) {
          toggleMenu();
        }
      });
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isMenuOpen) {
        toggleMenu();
      }
    });

    const navbar = document.getElementById("navbar");
    const logo = document.getElementById("logo-navbar");
    const menuIcon = document.getElementById("icon-menu");
    const closeIcon = document.getElementById("icon-close");

    const updateMenuColor = () => {
      if (isMenuOpen) {
        menuIcon?.classList.add("hidden");
        closeIcon?.classList.remove("hidden", "text-white", "text-navy");
        closeIcon?.classList.add("text-navy");
        logo?.classList.remove("text-white/85");
        logo?.classList.add("text-navy");
      } else {
        closeIcon?.classList.add("hidden");
        menuIcon?.classList.remove("hidden", "text-navy");
        logo?.classList.remove("text-navy");
        logo?.classList.add("text-white/85");

        if (window.scrollY > 100) {
          menuIcon?.classList.remove("text-white");
          menuIcon?.classList.add("text-navy");
          logo?.classList.remove("text-white/85");
          logo?.classList.add("text-navy");
        } else {
          menuIcon?.classList.remove("text-navy");
          menuIcon?.classList.add("text-white");
        }
      }
    };

    window.addEventListener("scroll", () => {
      if (window.scrollY > 100) {
        navbar?.classList.add("bg-white/95", "shadow-lg", "scrolled");
        navbar?.classList.remove("bg-transparent");
        logo?.classList.add("text-navy");
        logo?.classList.remove("text-white/85");
      } else {
        navbar?.classList.remove("bg-white/95", "shadow-lg", "scrolled");
        navbar?.classList.add("bg-transparent");
        logo?.classList.add("text-white/85");
        logo?.classList.remove("text-navy");
      }
      updateMenuColor();
    });

    // Initial check in case page is loaded already scrolled
    if (window.scrollY > 100) {
      navbar?.classList.add("bg-white/95", "shadow-lg", "scrolled");
      navbar?.classList.remove("bg-transparent");
    }
  });
</script>
