---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container container-footer">
    <div class="footer-brand">
      <a href="/" class="logo">
        <span class="logo-accent">MAJESTIC</span>MASS
      </a>
      <p>Empoderando tu futuro financiero con transparencia y rapidez.</p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4>Servicios</h4>
        <ul>
          <li><a href="#services">Autos</a></li>
          <li><a href="#services">Refinanciamiento</a></li>
          <li><a href="/seguros">Seguros</a></li>
        </ul>
      </div>
      <div class="link-group">
        <h4>Compañía</h4>
        <ul>
          <li><a href="/nosotros">Nosotros</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="#contact">Contacto</a></li>
        </ul>
      </div>
      <div class="link-group">
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacidad">Privacidad</a></li>
          <li><a href="/terminos">Términos</a></li>
        </ul>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} Majestic Mass. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #051a2b;
    color: var(--color-white);
    padding-top: var(--spacing-lg);
  }

  .container-footer {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
  }

  .footer-brand {
    max-width: 300px;
  }

  .logo {
    font-family: var(--font-secondary);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--color-white);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--spacing-sm);
  }

  .logo-accent {
    color: var(--color-blue);
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-xl);
  }

  .link-group h4 {
    margin-bottom: var(--spacing-sm);
    font-size: 1rem;
    color: var(--color-blue);
  }

  .link-group ul li {
    margin-bottom: 0.5rem;
  }

  .link-group ul li a {
    opacity: 0.7;
    font-size: 0.9rem;
    transition: opacity 0.3s ease;
  }

  .link-group ul li a:hover {
    opacity: 1;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: var(--spacing-sm) 0;
    text-align: center;
    font-size: 0.8rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .container-footer {
      flex-direction: column;
    }
    .footer-links {
      flex-wrap: wrap;
      gap: var(--spacing-md);
    }
  }
</style>
