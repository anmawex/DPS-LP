---
import { Phone, Headset } from "lucide-astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="contact">
  <div class="container contact-wrapper">
    <div class="contact-card">
      <div class="contact-main">
        <h2 class="contact-title">{t('contact.title')}</h2>
        <p class="contact-description">
          {t('contact.description')}
        </p>
        
        <div class="contact-actions">
          <a href="#empezar" class="btn btn-primary">{t('contact.btnStart')}</a>
          <a href="#conoce-mas" class="btn btn-outline-white">{t('contact.btnMore')}</a>
        </div>
      </div>

      <div class="contact-details-grid">
        <div class="contact-detail-item">
          <div class="icon-wrapper">
            <Phone size={24} />
          </div>
          <div class="detail-text">
            <span class="detail-label">{t('contact.office')}</span>
            <a href="tel:xxxxxxxxxx" class="detail-value">(xxx) xxx-xxxx</a>
          </div>
        </div>

        <div class="contact-detail-item">
          <div class="icon-wrapper">
            <Headset size={24} />
          </div>
          <div class="detail-text">
            <span class="detail-label">{t('contact.support')}</span>
            <a href="tel:xxxxxxxxxx" class="detail-value">(xxx) xxx-xxxx</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-navy);
    padding: 100px 0;
    color: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  /* Decorative background element */
  .contact::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--color-blue) 0%, transparent 70%);
    opacity: 0.15;
    pointer-events: none;
  }

  .contact-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg, 40px);
  }

  .contact-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--spacing-md, 24px);
    line-height: 1.1;
  }

  .contact-description {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: var(--spacing-lg, 40px);
    max-width: 600px;
    line-height: 1.6;
  }

  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm, 16px);
  }

  .contact-actions .btn {
    width: 100%;
  }

  .btn-outline-white {
    border: 2px solid var(--color-white);
    color: var(--color-white);
    background: transparent;
  }

  .btn-outline-white:hover {
    background: var(--color-white);
    color: var(--color-navy);
  }

  .contact-details-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg, 32px);
    background: rgba(255, 255, 255, 0.05);
    padding: 24px;
    border-radius: 24px;
  }

  .contact-detail-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md, 20px);
  }

  .icon-wrapper {
    width: 48px;
    height: 48px;
    background: var(--color-blue);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 8px 16px rgba(46, 134, 222, 0.3);
    flex-shrink: 0;
  }

  .detail-text {
    display: flex;
    flex-direction: column;
  }

  .detail-label {
    font-size: 0.8rem;
    opacity: 0.7;
    margin-bottom: 2px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .detail-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-white);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .detail-value:hover {
    color: var(--color-blue);
  }

  /* Desktop View */
  @media (min-width: 992px) {
    .contact-card {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      padding: var(--spacing-xl, 60px);
      border-radius: 40px;
    }

    .contact-description {
      font-size: 1.2rem;
    }

    .contact-actions {
      flex-direction: row;
    }

    .contact-actions .btn {
      width: auto;
    }

    .contact-details-grid {
      padding: var(--spacing-lg, 32px);
      border-radius: 30px;
    }

    .icon-wrapper {
      width: 56px;
      height: 56px;
      border-radius: 16px;
    }

    .detail-label {
      font-size: 0.9rem;
      margin-bottom: 4px;
    }

    .detail-value {
      font-size: 1.4rem;
    }
  }

</style>

